# Frontend (safe to expose — Supabase anon key is public by design)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Backend secrets — set these in your hosting provider's dashboard, NOT here.
# GEMINI_API_KEY=your-gemini-api-key

# GitHub Personal Access Token (PAT) — required for PR creation, recommended for analysis.
# Generate at https://github.com/settings/tokens with these scopes:
#   - repo (full control of private repositories) — needed to fork, commit, and open PRs
#   - public_repo (alternative if you only target public repos) — limits scope
#   - workflow (update GitHub Actions workflows)
# The PAT is a server-side secret stored in Supabase Edge Function secrets.
# GITHUB_TOKEN=github_pat_xxxxxxxxxxxx
